# =============================================================================
# ClawdAgent — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Node ---
NODE_ENV=development
PORT=3000

# --- AI (Required) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx
TELEGRAM_ADMIN_IDS=123456789,987654321

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_ADMIN_IDS=

# --- WhatsApp ---
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=./data/whatsapp-session

# --- Database (Required) ---
DATABASE_URL=postgresql://clawdagent:clawdagent@localhost:5432/clawdagent
REDIS_URL=redis://localhost:6379

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=

# --- Web Search ---
BRAVE_API_KEY=BSA_xxxxxxxxxxxx

# --- Provider Mode (controls AI provider priority) ---
# auto:    detect best available (CLI → API → OpenRouter)
# economy: OpenRouter free models → Anthropic fallback (cheapest)
# pro:     Anthropic API → OpenRouter fallback (best quality/cost balance)
# max:     Claude Code CLI → Anthropic → OpenRouter (FREE via Max subscription)
PROVIDER_MODE=auto

# --- Claude Code CLI (FREE via Max subscription — $200/month flat) ---
# Install: npm install -g @anthropic-ai/claude-code && claude login
# Priority: Claude Code (free) → Anthropic API → OpenRouter
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_PATH=claude

# --- Multi-Model (Optional — add for fallback + voice/TTS) ---
# Also used for Whisper (STT) and TTS
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_URL=

# --- Voice (requires OPENAI_API_KEY) ---
TTS_VOICE=nova

# --- OpenRouter (400+ models including FREE ones) ---
# Get API key at https://openrouter.ai/keys
# Free models handle background tasks, saving Anthropic credits for conversations
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1:free
OPENROUTER_ECONOMY_MODEL=deepseek/deepseek-v3-base:free

# --- Heartbeat (Proactive Monitoring) ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_MS=60000

# --- Desktop Control (AI sees and controls your screen) ---
DESKTOP_ENABLED=false
DESKTOP_MAX_ACTIONS_PER_MINUTE=60
DESKTOP_REQUIRE_CONFIRMATION=true

# --- MCP (Model Context Protocol — external tool servers) ---
# Comma-separated: id:command:args  (e.g. filesystem:npx:-y @modelcontextprotocol/server-filesystem /home)
MCP_SERVERS=

# --- Project Builder (AI builds full apps for you) ---
PROJECTS_DIR=./data/projects

# --- Cron / Scheduling ---
CRON_TIMEZONE=Asia/Jerusalem

# --- Email (Gmail API) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# --- Email (SMTP fallback) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Google Calendar (reuses Gmail OAuth or separate) ---
GOOGLE_REFRESH_TOKEN=

# --- Server Management ---
SSH_ENABLED=false

# --- Security ---
JWT_SECRET=change-this-to-a-real-secret-at-least-32-chars-long
ENCRYPTION_KEY=change-this-to-a-real-key-at-least-32-chars-long
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# --- Kie.ai (AI Content Generation — video, image, music, audio) ---
# Get API key at https://kie.ai/api-key
KIE_AI_API_KEY=

# --- Blotato (Social Media Publishing — 9 platforms) ---
# Get API key at https://my.blotato.com/settings/api
BLOTATO_API_KEY=
# Per-platform account IDs (find in Blotato dashboard)
BLOTATO_ACCOUNT_TWITTER=
BLOTATO_ACCOUNT_INSTAGRAM=
BLOTATO_ACCOUNT_FACEBOOK=
BLOTATO_ACCOUNT_LINKEDIN=
BLOTATO_ACCOUNT_TIKTOK=
BLOTATO_ACCOUNT_YOUTUBE=
BLOTATO_ACCOUNT_THREADS=
BLOTATO_ACCOUNT_BLUESKY=
BLOTATO_ACCOUNT_PINTEREST=

# --- ElevenLabs (TTS, Voice Cloning, Podcasts, Dubbing) ---
# Get API key at https://elevenlabs.io
ELEVENLABS_API_KEY=sk_xxxxx

# --- Firecrawl (Smart Web Scraping) ---
# Get API key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxx

# --- RapidAPI (40,000+ APIs) ---
# Get API key at https://rapidapi.com
RAPIDAPI_KEY=xxxxx

# --- Apify (Scrapers & Actors) ---
# Get API key at https://apify.com
APIFY_API_TOKEN=apify_api_xxxxx

# --- OpenClaw Bridge (remote AI system on VPS) ---
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

# --- Phone (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Multi-Server SSH ---
# Format: id|name|user@host:port|keyPath|workDir|tag1,tag2
SSH_SERVER_1=vps1|Main VPS|root@1.2.3.4:22|~/.ssh/key|/root|production,nodejs
SSH_SERVER_2=dev|Dev Server|root@5.6.7.8:22|~/.ssh/dev_key|/home/dev|development
#SSH_SERVER_3=
#SSH_SERVER_4=
#SSH_SERVER_5=

# --- Server Health Monitoring ---
SERVER_HEALTH_INTERVAL=300       # Check every 5 minutes (seconds)
SERVER_HEALTH_ALERTS=true        # Send Telegram alerts on issues
SERVER_AUTO_SCAN=true            # Auto-scan when first connecting
SERVER_SCAN_DEPTH=3              # Directory scan depth

# --- Logging ---
LOG_LEVEL=info
